{
  "name": "ai-triage-kiosk-demo",
  "version": "0.2.0",
  "private": true,
  "description": "English synthetic-data AI triage kiosk demo for workflow-support review.",
  "scripts": {
    "build": "node scripts/build-vercel.js",
    "mock:api": "node scripts/mock-api-server.js",
    "render:build": "npm run version:check && npm test && npm run smoke",
    "render:start": "node scripts/mock-api-server.js",
    "start": "python3 -m http.server 4183",
    "smoke": "node scripts/checks/smoke-demo.js",
    "test": "npm run test:unit && npm run test:contract",
    "test:unit": "node --test tests/unit/*.test.js",
    "test:contract": "node --test tests/contract/*.test.js",
    "version:check": "python3 scripts/check_version_control.py",
    "version:bump": "python3 scripts/bump_version.py",
    "version:bump:patch": "python3 scripts/bump_version.py --part patch",
    "version:bump:minor": "python3 scripts/bump_version.py --part minor",
    "version:bump:major": "python3 scripts/bump_version.py --part major",
    "demo:ready": "npm run version:check && npm test && npm run smoke && npm run build && git diff --check"
  },
  "keywords": [
    "ai-triage",
    "kiosk",
    "synthetic-data",
    "demo-only"
  ],
  "license": "UNLICENSED"
}
